# =============================================================================
# SplitSend - Environment Variables
# =============================================================================
# Copy this file to .env.local for development
# NEVER commit .env.local, .env, or any file with real secrets to version control
# For production, set these in Vercel Environment Variables dashboard
# =============================================================================


# Admin WhatsApp number (NEXT_PUBLIC_ so frontend can build wa.me link)
# Do NOT store this in any database table — env config only
NEXT_PUBLIC_ADMIN_WHATSAPP=2348168543901


# -----------------------------------------------------------------------------
# SUPABASE CONFIGURATION
# -----------------------------------------------------------------------------
# Public key: safe to expose in client-side code (NEXT_PUBLIC_ prefix)
# Get from: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# DANGER: Service role key has full database access — bypasses ALL Row Level Security
# NEVER expose to client — server-side only (no NEXT_PUBLIC_ prefix)
# Get from: Supabase Dashboard > Project Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here


# -----------------------------------------------------------------------------
# FLUTTERWAVE CONFIGURATION
# -----------------------------------------------------------------------------
# Public key: safe to expose in client-side code (NEXT_PUBLIC_ prefix)
# Get from: Flutterwave Dashboard > Settings > API Keys & Webhooks
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxx-X

# DANGER: Secret key — NEVER expose to client
# Used ONLY in server-side API routes for payment initialization and verification
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxx-X

# Webhook secret hash — set this SAME string in:
#   Flutterwave Dashboard > Settings > Webhooks > Secret Hash field
FLUTTERWAVE_SECRET_HASH=your-random-webhook-secret-here


# -----------------------------------------------------------------------------
# APPLICATION CONFIGURATION
# -----------------------------------------------------------------------------
# The base URL of your app (used for redirects, absolute URLs, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Connection fee — CONNECTION_FEE_KOBO is authoritative for all DB writes
# 100 kobo = ₦1 — so ₦2,000 = 200000 kobo
NEXT_PUBLIC_CONNECTION_FEE_NGN=2000
CONNECTION_FEE_KOBO=200000


# -----------------------------------------------------------------------------
# ADMIN CONFIGURATION
# -----------------------------------------------------------------------------
# Comma-separated list of admin user IDs (Supabase user UUIDs)
# Example: ADMIN_USER_IDS=uuid1,uuid2,uuid3
ADMIN_USER_IDS=your-admin-supabase-user-uuid-here


# -----------------------------------------------------------------------------
# RATE LIMITING CONFIGURATION
# -----------------------------------------------------------------------------
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_MS=60000
MAX_POSTS_PER_USER_PER_DAY=3


# -----------------------------------------------------------------------------
# EMAIL CONFIGURATION (Optional - for future email notifications)
# -----------------------------------------------------------------------------
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@splitsend.ng
# SMTP_PASS=your-smtp-password
# EMAIL_FROM=SplitSend <noreply@splitsend.ng>


# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL=info
ENABLE_REMOTE_LOGGING=false


# -----------------------------------------------------------------------------
# SECURITY
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
APP_SECRET=your-random-secret-string-min-32-chars


# =============================================================================
# ENVIRONMENT NOTES
# =============================================================================
# Development: Use Flutterwave test keys (FLWPUBK_TEST-, FLWSECK_TEST-)
# Production:  Use live keys (FLWPUBK-, FLWSECK-)
#
# Vercel Deployment:
#   - Add all variables in Vercel Dashboard > Project > Settings > Env Variables
#   - Set appropriate values per environment (Development, Preview, Production)
#   - Mark sensitive vars (SUPABASE_SERVICE_ROLE_KEY, FLUTTERWAVE_SECRET_KEY,
#     FLUTTERWAVE_SECRET_HASH) as Production secrets
#
# GitHub Repository:
#   - Enable Dependabot for automated security updates
#   - Enable GitHub secret scanning to detect accidental key commits
#   - Never commit this file with real values
# =============================================================================
