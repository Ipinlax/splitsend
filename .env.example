# =============================================================================
# SplitSend - Environment Variables
# =============================================================================
# Copy this file to .env.local for development
# NEVER commit .env.local, .env, or any file with real secrets to version control
# For production, set these in Vercel Environment Variables dashboard
# =============================================================================


# Admin WhatsApp number (NEXT_PUBLIC_ so frontend can build wa.me link)
# Do NOT store this in any database table — env config only
NEXT_PUBLIC_ADMIN_WHATSAPP=2348168543901


# -----------------------------------------------------------------------------
# SUPABASE CONFIGURATION
# -----------------------------------------------------------------------------
# Public key: safe to expose in client-side code (NEXT_PUBLIC_ prefix)
# Get from: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# DANGER: Service role key has full database access — bypass ALL Row Level Security
# NEVER expose to client — server-side only (no NEXT_PUBLIC_ prefix)
# Get from: Supabase Dashboard > Project Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here


# -----------------------------------------------------------------------------
# PAYSTACK CONFIGURATION
# -----------------------------------------------------------------------------
# Public key: safe to expose in client-side code (used to initialize popup)
# Get from: Paystack Dashboard > Settings > API Keys & Webhooks
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your-paystack-public-key

# DANGER: Secret key — NEVER expose to client
# Used ONLY in server-side API routes for transaction verification
PAYSTACK_SECRET_KEY=sk_test_your-paystack-secret-key

# Paystack webhook secret for verifying webhook signatures
PAYSTACK_WEBHOOK_SECRET=your-paystack-webhook-secret


# -----------------------------------------------------------------------------
# APPLICATION CONFIGURATION
# -----------------------------------------------------------------------------
# The base URL of your app (used for redirects, absolute URLs, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Connection fee in kobo (100 kobo = ₦1; ₦2000 = 200000 kobo)
NEXT_PUBLIC_CONNECTION_FEE_NGN=2000
CONNECTION_FEE_KOBO=200000


# -----------------------------------------------------------------------------
# ADMIN CONFIGURATION
# -----------------------------------------------------------------------------
# Comma-separated list of admin user IDs (Supabase user UUIDs)
# Add UUID of users who should have admin access
# Example: ADMIN_USER_IDS=uuid1,uuid2,uuid3
ADMIN_USER_IDS=your-admin-supabase-user-uuid-here


# -----------------------------------------------------------------------------
# RATE LIMITING CONFIGURATION
# -----------------------------------------------------------------------------
# Maximum number of requests per window per IP
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_MS=60000

# Max posts per user per day
MAX_POSTS_PER_USER_PER_DAY=3


# -----------------------------------------------------------------------------
# EMAIL CONFIGURATION (Optional - for future email notifications)
# -----------------------------------------------------------------------------
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@splitsend.ng
# SMTP_PASS=your-smtp-password
# EMAIL_FROM=SplitSend <noreply@splitsend.ng>


# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
# Log level: debug | info | warn | error
LOG_LEVEL=info
# Set to true in production to send logs to external service
ENABLE_REMOTE_LOGGING=false


# -----------------------------------------------------------------------------
# SECURITY
# -----------------------------------------------------------------------------
# Secret for signing internal tokens (min 32 chars, random string)
# Generate with: openssl rand -base64 32
APP_SECRET=your-random-secret-string-min-32-chars


# =============================================================================
# ENVIRONMENT NOTES
# =============================================================================
# Development: Use test keys for Paystack (pk_test_, sk_test_)
# Production:  Use live keys (pk_live_, sk_live_)
#
# Vercel Deployment:
#   - Add all variables in Vercel Dashboard > Project > Settings > Env Variables
#   - Set appropriate values per environment (Development, Preview, Production)
#   - Mark sensitive vars (SUPABASE_SERVICE_ROLE_KEY, PAYSTACK_SECRET_KEY) as
#     "Production" only or encrypted secrets
#
# GitHub Repository:
#   - Enable Dependabot for automated security updates
#   - Enable GitHub secret scanning to detect accidental key commits
#   - Never commit this file with real values
# =============================================================================
