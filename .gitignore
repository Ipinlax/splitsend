# =============================================================================
# SplitSend .gitignore
# =============================================================================

# CRITICAL: Never commit secrets or environment files
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging
.env.preview
*.pem
*.key
*.cert
*.p12
secrets/
config/secrets/

# Next.js
.next/
out/
build/

# Dependencies
node_modules/
.pnp
.pnp.js

# Testing
coverage/
.nyc_output/
*.lcov

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Editor directories
.vscode/
.idea/
*.swp
*.swo
*.swn
*.bak
*.tmp

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Misc
.vercel
.turbo
.cache/
dist/

# Debug
npm-debug.log*

# Optional: yarn v2+
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*
